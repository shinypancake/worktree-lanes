#!/usr/bin/env bash
# Installs dependencies for the current repo/worktree.
#
# Local mode keeps the fast non-main worktree symlink behavior. CI mode always
# runs deterministic installs and never reuses another worktree's node_modules.

set -euo pipefail

CI_MODE=0

usage() {
  cat <<'EOF'
Usage:
  worktree bootstrap
  worktree bootstrap --ci

Options:
  --ci       Run deterministic CI installs (npm ci, no node_modules symlinks)
  -h, --help Show help
EOF
}

while [ $# -gt 0 ]; do
  case "$1" in
    --ci) CI_MODE=1 ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown arg: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
  shift
done

# Use a mutex lock to prevent concurrent npm installs from racing on the same
# node_modules directory when multiple CI jobs land on the same self-hosted runner.
# flock -w 300 waits up to 5 minutes for the lock before failing.
# flock is Linux-only; fall back to direct execution on macOS (no ETXTBSY risk there).
WORKTREE_ROOT=$(git rev-parse --show-toplevel 2>/dev/null || pwd -P)
MAIN_REPO=$(git worktree list --porcelain 2>/dev/null | awk '/^worktree/{print $2; exit}')
NPM_LOCK="/tmp/${WORKTREE_ROOT##*/}-npm-install.lock"

if command -v flock >/dev/null 2>&1; then
  npm_install() { flock -w 300 "$NPM_LOCK" bash -c "$1"; }
else
  npm_install() { eval "$1"; }
fi

link_or_install() {
  local target_dir="$1"    # path relative to worktree root (e.g. "." or "frontend")
  local install_cmd="$2"   # command to run if symlinking isn't possible

  local dest
  if [ "$target_dir" = "." ]; then
    dest="$WORKTREE_ROOT/node_modules"
  else
    dest="$WORKTREE_ROOT/$target_dir/node_modules"
  fi

  # Already a symlink or a populated directory — nothing to do.
  # An empty directory (e.g. Docker-created volume stub) is NOT considered set up.
  if [ -L "$dest" ]; then
    return 0
  fi
  if [ -d "$dest" ] && [ -n "$(ls -A "$dest" 2>/dev/null)" ]; then
    return 0
  fi

  # In a non-main worktree: try to symlink from the primary worktree.
  if [ "$WORKTREE_ROOT" != "$MAIN_REPO" ]; then
    local source
    if [ "$target_dir" = "." ]; then
      source="$MAIN_REPO/node_modules"
    else
      source="$MAIN_REPO/$target_dir/node_modules"
    fi

    if [ -d "$source" ]; then
      echo "    Symlinking $dest -> $source"
      ln -s "$source" "$dest"
      return 0
    fi
    echo "    Primary worktree node_modules not found at $source — falling back to npm install"
  fi

  npm_install "$install_cmd"
}

if [ "$CI_MODE" -eq 1 ]; then
  echo "==> Setting up root npm dependencies (ci)"
  npm_install "npm ci"

  echo "==> Setting up frontend npm dependencies (ci)"
  npm_install "cd frontend && npm ci"
else
  echo "==> Setting up root npm dependencies"
  link_or_install "." "npm install"

  echo "==> Setting up frontend npm dependencies"
  link_or_install "frontend" "cd frontend && npm install"
fi

if command -v docker >/dev/null 2>&1; then
  echo "==> Checking Docker availability"
  if docker info >/dev/null 2>&1; then
    echo "Docker is available."
    # Build the backend image so the backend/sidekiq containers boot with the
    # current gems. Skipped in CI, where lanes build the image fresh.
    if [ "$CI_MODE" -eq 0 ]; then
      echo "==> Building backend image"
      worktree sync-gems
    fi
  else
    echo "WARNING: Docker CLI found, but daemon is not reachable."
    echo "         Start Docker Desktop before running backend commands."
  fi
else
  echo "WARNING: Docker CLI not found. Backend commands require Docker."
fi

echo "==> Bootstrap complete"
